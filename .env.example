# --- App ---
APP_NAME=AI Invoice & Document Processing Automation System
ENV=development            # development | production
DEMO_MODE=true              # true = use mock text extraction + mock AI (no Tesseract/AI key needed)

# --- Database ---
# For local/demo use SQLite (no setup needed):
DATABASE_URL=sqlite:///./app.db
# For PostgreSQL, use something like:
# DATABASE_URL=postgresql://user:password@localhost:5432/doc_automation

# --- File storage ---
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10
ALLOWED_FILE_TYPES=pdf,png,jpg,jpeg

# --- OCR (only used when DEMO_MODE=false) ---
# Path to the tesseract binary, if not on PATH (e.g. on Windows)
TESSERACT_CMD=

# --- AI Analysis (Anthropic Claude) ---
# Only required when DEMO_MODE=false
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Classification thresholds ---
CLASSIFICATION_AUTO_THRESHOLD=0.80
CLASSIFICATION_REVIEW_THRESHOLD=0.60

# --- Validation rules ---
HIGH_AMOUNT_WARNING_THRESHOLD=10000
VALID_CURRENCIES=MYR,USD,SGD

# --- Export ---
EXPORT_DIR=./exports
